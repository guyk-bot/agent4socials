# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/topost?schema=public"
# Direct connection for migrations (Supabase: same URL as DATABASE_URL but port 5432)
# On Vercel/Supabase: use Transaction pooler (port 6543) and add ?connection_limit=1 to avoid "Timed out fetching a new connection from the connection pool" (500/508).
DATABASE_DIRECT_URL="postgresql://postgres:postgres@localhost:5432/topost?schema=public"
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=topost

# Redis (optional - for scheduled posts; use Redis Cloud or Upstash)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Auth (Supabase: use JWT Secret from Supabase Dashboard > Project Settings > API)
SUPABASE_JWT_SECRET=
JWT_SECRET=super-secret-key-change-me
ENCRYPTION_KEY=change-me-to-a-32-char-secret-key!!
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Social Media API Keys (for production use https://api.agent4socials.com/... callbacks)
# Meta (Instagram)
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:3001/api/social/oauth/instagram/callback

# TikTok
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:3001/api/social/oauth/tiktok/callback

# YouTube (Google)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:3001/api/social/oauth/youtube/callback

# Facebook (Meta - separate from Instagram; use for Pages)
FACEBOOK_REDIRECT_URI=http://localhost:3001/api/social/oauth/facebook/callback

# X (Twitter)
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_REDIRECT_URI=http://localhost:3001/api/social/oauth/twitter/callback

# LinkedIn (Community Management / Marketing REST — YYYYMM version header on /rest/* calls)
# LINKEDIN_REST_API_VERSION=202602
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:3001/api/social/oauth/linkedin/callback
# OAuth scopes: defaults are openid profile email. Enable write + org flows only after LinkedIn Developer Portal products approve them.
# LINKEDIN_INCLUDE_W_MEMBER_SOCIAL=true
# LINKEDIN_INCLUDE_R_MEMBER_SOCIAL=true
# LINKEDIN_REQUEST_ORG_SCOPES=true
# Or set the full scope string from Microsoft Learn (Community Management API):
# LINKEDIN_OAUTH_SCOPES=openid profile email w_member_social r_member_social r_organization_social w_organization_social

# Object Storage (S3/R2) – required for Composer image/video uploads
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
S3_REGION=
# For R2: public URL so platforms (LinkedIn, X, etc.) can load media
S3_PUBLIC_URL=

# Resend
RESEND_API_KEY=
# General sender fallback (support and other transactional emails)
RESEND_FROM_EMAIL=Agent4Socials <guyk@agent4socials.com>
# Welcome/verification emails (new users)
RESEND_WELCOME_FROM_EMAIL=Agent4Socials <guyk@agent4socials.com>
# Scheduled-post emails ("your post is ready")
RESEND_SCHEDULED_FROM_EMAIL=Agent4Socials <noreply@agent4socials.com>

# Cron (for scheduled posts: set CRON_SECRET and call GET /api/cron/process-scheduled with header X-Cron-Secret)
CRON_SECRET=
# Wall-clock budget for GET /api/cron/sync-platform-data (all scopes share one deadline). Default 26000 fits cron-job.org free (30s HTTP max).
# CRON_SYNC_HTTP_BUDGET_MS=26000

# Per-user API usage (usage_daily). Comma-separated emails allowed to call GET /api/admin/usage?all=1
ADMIN_USAGE_EMAILS=
# Set to 1 to stop incrementing api_request on every authenticated API call
# USAGE_METER_DISABLE=1

# Comment automation volume (optional — see apps/web/docs/COMMENT_AUTOMATION.md)
# COMMENT_AUTOMATION_MAX_POSTS=40
# COMMENT_AUTOMATION_MAX_META_COMMENT_PAGES=25
# COMMENT_AUTOMATION_MAX_REPLIES_PER_TARGET=40
# COMMENT_AUTOMATION_MAX_TWITTER_PAGES=8
# COMMENT_AUTOMATION_INTER_PAGE_DELAY_MS=120
# COMMENT_AUTOMATION_INTER_REPLY_DELAY_MS=150
# Wall-clock budget for GET /api/cron/comment-automation (default 24000 ms for 30s HTTP schedulers).
# COMMENT_AUTOMATION_CRON_BUDGET_MS=24000

# OpenAI (optional: AI post descriptions, inbox replies, reel captions/analysis; set in apps/web/.env and Vercel)
OPENAI_API_KEY=
# Optional: chat model (default gpt-4o-mini)
# OPENAI_CHAT_MODEL=gpt-4o-mini

# App URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:3001
