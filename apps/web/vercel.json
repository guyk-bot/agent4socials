{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "env": { "NODE_OPTIONS": "--no-deprecation" },
  "functions": {
    "app/api/media/upload/route.ts": { "maxDuration": 60 },
    "app/api/social/oauth/[platform]/callback/route.ts": { "maxDuration": 60 },
    "app/api/posts/[id]/publish/route.ts": { "maxDuration": 300 },
    "app/api/social/accounts/[id]/conversations/route.ts": { "maxDuration": 60 },
    "app/api/inbox/instagram-dms/route.ts": { "maxDuration": 60 },
    "app/api/ai/aysop-chat/route.ts": { "maxDuration": 120 }
  }
}
